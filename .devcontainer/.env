# Copy this file to `.env` and customize if needed:
#   cp .env.example .env
#
# Most users don't need to touch this - the defaults work.
# Only change if your host UID/GID is not 1000 (run `id` to check).

# Host user ID (must match `id -u` on host so file ownership is correct)
USER_UID=1001

# Host group ID (must match `id -g` on host)
USER_GID=1001
